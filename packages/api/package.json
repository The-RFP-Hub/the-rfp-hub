{
  "name": "@rfp-hub/api",
  "version": "0.0.0",
  "private": true,
  "description": "RFP Hub public /v1/ REST API (Fastify + Postgres) serving the RFP Hub Standard.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "migrate": "tsx scripts/migrate.ts",
    "seed": "tsx scripts/seed.ts",
    "export": "tsx scripts/export.ts"
  },
  "dependencies": {
    "@fastify/swagger": "^9.4.2",
    "@fastify/swagger-ui": "^5.2.1",
    "@rfp-hub/standard": "workspace:*",
    "drizzle-orm": "^0.38.3",
    "fastify": "^5.2.1",
    "pg": "^8.13.1",
    "rfphub-validate": "workspace:*"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/The-RFP-Hub/the-rfp-hub",
    "directory": "packages/api"
  }
}
