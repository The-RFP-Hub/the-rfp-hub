# RFP Hub /v1/ API — local environment (M2)
# Copy to .env and adjust. Matches packages/api/docker-compose.yml defaults.

# Postgres connection string
DATABASE_URL=postgres://rfphub:rfphub@localhost:5432/rfphub

# HTTP server
PORT=3001
HOST=0.0.0.0

# ── Seed source (deployment-specific; the seed script ingests from here) ──────────────
# Base URL of an upstream funding-map registry API exposing /v2/program-registry/search.
SOURCE_API_URL=
# Provenance namespace stamped on seeded entries (source_system column + `<system>:<id>` public id).
SOURCE_SYSTEM=fundingmap
# Base URL for a program's page on the source, used as a provenance fallback (no trailing slash).
SOURCE_PROGRAM_URL_BASE=
